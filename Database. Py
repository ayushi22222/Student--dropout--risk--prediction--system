import sqlite3

# Database create/connect
conn = sqlite3.connect("students.db")

cursor = conn.cursor()

# Student table create
cursor.execute("""
CREATE TABLE IF NOT EXISTS students(
    name INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT,
    attendance REAL,
    marks REAL,
    assignment TEXT,
    fee_pending TEXT,
    risk_score INTEGER,
    risk_level TEXT
)
""")

conn.commit()


# Student data save function
def add_student(name, attendance, marks, assignment, fee_pending, score level):

    cursor.execute("""
    INSERT INTO students
    (name, attendance, marks, assignment, fee_pending, risk_score, risk_level)
    VALUES (?, ?, ?, ?, ?, ?, ?)
    """,
    (name, attendance, marks, assignment, fee_pending, score, level))

    conn.commit()


# Show all students
def show_students():

    cursor.execute("SELECT * FROM students")
    data = cursor.fetchall()

    return data


print("Database Created Successfully")
