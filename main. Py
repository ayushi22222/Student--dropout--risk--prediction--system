def calculate_risk(attendance, marks, assignment, behavior, fee_pending, counseling):

    risk = 0

    # Attendance
    if attendance < 60:
        risk += 30
    elif attendance < 75:
        risk += 15

    # Marks
    if marks < 40:
        risk += 25
    elif marks < 60:
        risk += 10

    # Assignment
    if assignment.lower() == "no":
        risk += 15

    # Behavior
    if behavior.lower() == "poor":
        risk += 10

    # Pending Fee 
    if fee_pending.lower() == "yes":
        risk += 10

    # Counseling
    if counseling.lower() == "yes":
        risk += 10 
        return risk

