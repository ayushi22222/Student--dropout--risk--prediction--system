def calculate_risk(attendance, marks, assignment, behavior, fee_pending, counseling):
    risk = 0

    if attendance < 60:
        risk += 30
    elif attendance < 75:
        risk += 15

    if marks < 40:
        risk += 25
    elif marks < 60:
        risk += 10

    if assignment.lower() == "no":
        risk += 15

    if behavior.lower() == "poor":
        risk += 10

    if fee_pending.lower() == "yes":
        risk += 10

    if counseling.lower() == "yes":
        risk += 10

    return risk


print("===== Student Dropout Risk Prediction System =====")

name = input("Enter Student Name: ")
attendance = float(input("Attendance Percentage: "))
marks = float(input("Average Marks: "))
assignment = input("Assignment Submitted (Yes/No): ")
behavior = input("Behavior (Good/Poor): ")
fee_pending = input("Fee Pending (Yes/No): ")
counseling = input("Counseling Required (Yes/No): ")

risk = calculate_risk(attendance, marks, assignment, behavior, fee_pending, counseling)

print("\n------ Result ------")
print("Student Name:", name)
print("Risk Score:", risk)

if risk <= 30:
    level = "LOW"
elif risk <= 60:
    level = "MEDIUM"
else:
    level = "HIGH"

print("Risk Level:", level)
print("Project Completed Successfully")
